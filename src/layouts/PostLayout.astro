---
import BaseLayout from './BaseLayout.astro';

export interface Props {
  title: string;
  date: Date;
  description: string;
  readingTime: number;
}

const { title, date, description, readingTime } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={`${title} — Portfolio`} description={description}>
  <article>
    <header style="margin-bottom: 2.5rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--color-border);">
      <h1 style="font-family: var(--font-serif); font-size: 2rem; font-weight: 700; line-height: 1.25; letter-spacing: -0.03em; color: var(--color-text); margin: 0 0 0.75rem;">
        {title}
      </h1>
      <div style="display: flex; gap: 1rem; align-items: center; font-size: 0.875rem; color: var(--color-muted);">
        <time datetime={date.toISOString()}>{formattedDate}</time>
        <span>·</span>
        <span>{readingTime} min read</span>
      </div>
    </header>

    <div class="prose">
      <slot />
    </div>

    <footer style="margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid var(--color-border);">
      <a href="/blog" style="font-size: 0.875rem;">← Back to all posts</a>
    </footer>
  </article>
</BaseLayout>
