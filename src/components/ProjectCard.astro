---
import type { Project } from '../data/projects';

export interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<article style="
  padding: 1.25rem 0;
  border-bottom: 1px solid var(--color-border);
">
  <div style="display: flex; align-items: baseline; justify-content: space-between; gap: 1rem; margin-bottom: 0.375rem;">
    <h3 style="
      margin: 0;
      font-family: var(--font-serif);
      font-size: 1.0625rem;
      font-weight: 600;
      letter-spacing: -0.01em;
    ">
      <a
        href={project.url}
        target="_blank"
        rel="noopener noreferrer"
        style="color: var(--color-text); text-decoration: none;"
      >
        {project.name}
        <span style="font-family: var(--font-sans); font-size: 0.75rem; color: var(--color-muted); font-weight: 400; margin-left: 0.25rem;">↗</span>
      </a>
    </h3>
  </div>

  <p style="
    margin: 0 0 0.625rem;
    font-size: 0.9rem;
    color: var(--color-muted);
    line-height: 1.55;
  ">
    {project.description}
  </p>

  <div style="display: flex; flex-wrap: wrap; gap: 0.375rem;">
    {project.tech.map((tag) => (
      <span style="
        font-family: var(--font-mono);
        font-size: 0.75rem;
        background: var(--color-tag-bg);
        color: var(--color-tag-text);
        padding: 0.15em 0.5em;
        border-radius: 4px;
        border: 1px solid var(--color-border);
      ">
        {tag}
      </span>
    ))}
  </div>
</article>
