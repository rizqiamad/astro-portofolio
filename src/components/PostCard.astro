---
export interface Props {
  title: string;
  date: Date;
  description: string;
  slug: string;
}

const { title, date, description, slug } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article style="
  padding: 1.25rem 0;
  border-bottom: 1px solid var(--color-border);
">
  <div style="
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.25rem;
    margin-bottom: 0.375rem;
  ">
    <a
      href={`/blog/${slug}`}
      style="
        font-family: var(--font-serif);
        font-size: 1.0625rem;
        font-weight: 600;
        color: var(--color-text);
        text-decoration: none;
        letter-spacing: -0.01em;
        line-height: 1.4;
      "
    >
      {title}
    </a>
    <time
      datetime={date.toISOString()}
      style="font-size: 0.8125rem; color: var(--color-muted); white-space: nowrap; flex-shrink: 0;"
    >
      {formattedDate}
    </time>
  </div>
  <p style="
    margin: 0;
    font-size: 0.9rem;
    color: var(--color-muted);
    line-height: 1.55;
  ">
    {description}
  </p>
</article>
